<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="6dp"
            android:text="Nova tarefa"
            android:textColor="#FFFFFF"
            android:textSize="32sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="26dp"
            android:text="Segundo INSERT do projeto"
            android:textColor="#DDEEEE"
            android:textSize="15sp" />

        <EditText
            android:id="@+id/edit_codigo_tarefa"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginBottom="12dp"
            android:background="@drawable/bg_input"
            android:hint="Código da tarefa. Ex: T001"
            android:inputType="text"
            android:paddingStart="18dp"
            android:paddingEnd="18dp" />

        <EditText
            android:id="@+id/edit_titulo_tarefa"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginBottom="12dp"
            android:background="@drawable/bg_input"
            android:hint="Título"
            android:inputType="textCapSentences"
            android:paddingStart="18dp"
            android:paddingEnd="18dp" />

        <EditText
            android:id="@+id/edit_descricao_tarefa"
            android:layout_width="match_parent"
            android:layout_height="100dp"
            android:layout_marginBottom="12dp"
            android:background="@drawable/bg_input"
            android:gravity="top"
            android:hint="Descrição"
            android:inputType="textMultiLine|textCapSentences"
            android:padding="18dp" />

        <EditText
            android:id="@+id/edit_status_tarefa"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginBottom="12dp"
            android:background="@drawable/bg_input"
            android:hint="Status. Ex: Pendente"
            android:inputType="textCapSentences"
            android:paddingStart="18dp"
            android:paddingEnd="18dp" />

        <EditText
            android:id="@+id/edit_data_entrega_tarefa"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginBottom="22dp"
            android:background="@drawable/bg_input"
            android:hint="Data de entrega. Ex: 20/07/2026"
            android:inputType="date"
            android:paddingStart="18dp"
            android:paddingEnd="18dp" />

        <Button
            android:id="@+id/bt_salvar_tarefa"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginBottom="12dp"
            android:background="@drawable/bg_button"
            android:text="SALVAR TAREFA"
            android:textColor="#FFFFFF"
            android:textStyle="bold" />

        <Button
            android:id="@+id/bt_voltar_cadastro_tarefa"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@drawable/bg_button"
            android:text="VOLTAR"
            android:textColor="#FFFFFF"
            android:textStyle="bold" />

        <ProgressBar
            android:id="@+id/progressbar_tarefa"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:visibility="gone" />

    </LinearLayout>
</ScrollView>
