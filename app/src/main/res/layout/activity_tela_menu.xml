<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:padding="24dp">

        <ImageView
            android:layout_width="88dp"
            android:layout_height="88dp"
            android:layout_marginTop="18dp"
            android:layout_marginBottom="12dp"
            android:contentDescription="Logo StudyFlow"
            android:src="@drawable/ic_studyflow_logo" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="StudyFlow"
            android:textColor="#FFFFFF"
            android:textSize="34sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/text_usuario_menu"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:layout_marginBottom="26dp"
            android:text="usuario@email.com"
            android:textColor="#DDEEEE"
            android:textSize="14sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_card"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:text="Menu principal"
                android:textColor="#FFFFFF"
                android:textSize="22sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/bt_menu_perfil"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginBottom="12dp"
                android:background="@drawable/bg_button"
                android:text="MEU PERFIL"
                android:textColor="#FFFFFF" />

            <Button
                android:id="@+id/bt_menu_cadastrar_tarefa"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginBottom="12dp"
                android:background="@drawable/bg_button"
                android:text="CADASTRAR TAREFA"
                android:textColor="#FFFFFF" />

            <Button
                android:id="@+id/bt_menu_buscar_tarefa"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginBottom="12dp"
                android:background="@drawable/bg_button"
                android:text="BUSCAR 1 REGISTRO / UPDATE"
                android:textColor="#FFFFFF" />

            <Button
                android:id="@+id/bt_menu_listar_tarefas"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginBottom="12dp"
                android:background="@drawable/bg_button"
                android:text="LISTA PAGINADA"
                android:textColor="#FFFFFF" />

            <Button
                android:id="@+id/bt_menu_sobre"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginBottom="12dp"
                android:background="@drawable/bg_button"
                android:text="SOBRE O APP"
                android:textColor="#FFFFFF" />

            <Button
                android:id="@+id/bt_menu_sair"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:background="@drawable/bg_button"
                android:text="SAIR"
                android:textColor="#FFFFFF" />

        </LinearLayout>
    </LinearLayout>
</ScrollView>
